{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "pyright": {
      "disabled": true
    }
  },
  "provider": {
    "lmstudio": {
      "models": {
        "omnicoder-9b": {
          "name": "omnicoder-9b",
          "tools": true,
          "limit": { "context": 100352, "output": 16384 }
        }
      },
      "name": "LMStudio",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://romulus:1234/v1"
      }
    },
    "ollama": {
      "models": {
        "carstenuhlig/omnicoder-9b": {
          "name": "omnicoder",
          "limit": { "context": 100352, "output": 16384 }
        },
        "llama3.1-64k": {
          "name": "Llama 3.1",
          "limit": { "context": 262144, "output": 16384 }
        },
        "omnicoder-98k": {
          "name": "OmniCoder",
          "tools": true,
          "limit": {
            "context": 100352,
            "output": 16384
          }
        }
      },
      "name": "Ollama (romulus)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://romulus:11434/v1"
      }
    }
  },
  "mode": {
    "build": {
      "model": "lmstudio/omnicoder-9b"
    },
    "plan": {
      "model": "anthropic/claude-opus-4-6"
    },
    "default": {
      "model": "lmstudio/omnicoder-9b"
    }
  },
  "command": {
    "coderabbit": {
      "template": "!coderabbit review --prompt-only\n\nFix all issues reported above.",
      "description": "Reviews code with CodeRabbit and fixes issues"
    }
  }
}
