{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "pyright": {
      "disabled": true
    }
  },
  "plugin": ["opencode-claude-auth", "@tarquinen/opencode-dcp@latest"],
  "disabled_providers": [
    "github-copilot",
    "github-copilot-enterprise",
    "github-models"
  ],
  "provider": {
    "romulus": {
      "name": "Romulus",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://romulus:11434/v1"
      },
      "models": {
        "gemma-4-e2b-it": {
          "name": "Gemma 4 e2b",
          "tools": true,
          "tool_call": true,
          "limit": {
            "context": 32768,
            "output": 16384
          }
        },
        "qwen3.5-35b-a3b-apex": {
          "name": "Qwen3.5 35b APEX",
          "tools": true,
          "tool_call": true,
          "modalities": { "input": ["image", "text"], "output": ["text"] },
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "deltacoder": {
          "name": "deltacoder",
          "tools": true,
          "reasoning": false,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 204800,
            "output": 32768
          },
          "steps": 25,
          "permission": {
            "doom_loop": "deny"
          },
          "variants": {
            "medium": {
              "temperature": 0.6,
              "think": true,
              "thinking_budget": 4096
            },
            "high": {
              "temperature": 1.0,
              "think": true,
              "thinking_budget": 16384
            }
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "romulus/qwen3.5-35b-a3b-apex",
      "steps": 12,
      "permission": {
        "*": "allow",
        "task": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "variant": "high",
      "permission": {
        "edit": {
          "*": "ask",
          "docs/*": "allow",
          "TODO.md": "allow"
        },
        "bash": "allow",
        "task": "allow"
      }
    },
    "reviewer": {
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-6",
      "variant": "high",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "task": "deny"
      }
    }
  },
  "experimental": {
    "bash": {
      "timeout_ms": 600000
    }
  }
}
