{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow"
  },
  "provider": {
    "ollama-chonkpad": {
      "models": {
        "qwen2.5-coder:7b": {
          "name": "qwen2.5-coder:7b",
          "tools": true,
          "limit": { "context": 32768, "output": 4096 }
        },
        "qwen3.5-4b": {
          "name": "qwen3.5-4b",
          "tools": true,
          "limit": { "context": 32768, "output": 4096 }
        }
      },
      "name": "Ollama (chonkpad)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    },
    "lmstudio": {
      "models": {
        "unsloth/qwen3.5-9b": {
          "name": "qwen3.5-9b",
          "limit": { "context": 49152, "output": 4096 }
        },
        "unsloth/qwen3.5-4b": {
          "name": "qwen3.5-4b",
          "limit": { "context": 65536, "output": 4096 }
        }
      },
      "name": "LM Studio",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://romulus:1234/v1"
      }
    },
    "ollama": {
      "models": {
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b",
          "tools": true,
          "limit": { "context": 65536, "output": 4096 }
        },
        "qwen2.5-coder:14b": {
          "name": "qwen2.5-coder:14b",
          "tools": true,
          "limit": { "context": 32768, "output": 4096 }
        },
        "qwen3.5-9b-49k": {
          "name": "qwen3.5:9b (49k)",
          "tools": true,
          "limit": {
            "context": 49152,
            "output": 4096
          },
          "options": {
            "reasoningEffort": "none"
          },
          "variants": {
            "thinking": {
              "reasoningEffort": "low"
            }
          }
        }
      },
      "name": "Ollama (romulus)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://romulus:11434/v1"
      }
    }
  },
  "mode": {
    "build": {
      "model": "lmstudio/unsloth/qwen3.5-9b"
    },
    "plan": {
      "model": "anthropic/claude-opus-4-6"
    }
  },
  "command": {
    "coderabbit": {
      "template": "run the command `coderabbit review --prompt-only`",
      "description": "Reviews Changes with Coderabbit"
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"]
    }
  }
}
