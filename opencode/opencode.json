{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "pyright": {
      "disabled": true
    }
  },
  "plugin": ["opencode-gemini-auth@latest", "opencode-claude-auth"],
  "disabled_providers": [
    "github-copilot",
    "github-copilot-enterprise",
    "github-models"
  ],
  "provider": {
    "romulus": {
      "name": "Romulus",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://romulus:11434/v1"
      },
      "models": {
        "omnicoder": {
          "name": "Omnicoder 9b",
          "tools": true,
          "reasoning": false,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 163840,
            "output": 32768
          },
          "steps": 25,
          "permission": {
            "doom_loop": "deny"
          }
        },
        "deltacoder": {
          "name": "deltacoder",
          "tools": true,
          "reasoning": false,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "steps": 25,
          "permission": {
            "doom_loop": "deny"
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "romulus/deltacoder",
      "permission": {
        "*": "allow",
        "task": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "permission": {
        "edit": {
          "*": "ask",
          "docs/*": "allow",
          "TODO.md": "allow"
        },
        "bash": "allow",
        "task": "allow"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "romulus/deltacoder"
    },
    "explore": {
      "mode": "subagent",
      "model": "romulus/deltacoder"
    },
    "reviewer": {
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-6",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "task": "deny"
      }
    }
  },
  "experimental": {
    "bash": {
      "timeout_ms": 600000
    }
  }
}
