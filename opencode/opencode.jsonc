{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-tama@latest"],
  "permission": "allow",
  "command": {
    "review": {
      "template": "Load the `review` skill using the skill tool, then execute its instructions to review: $ARGUMENTS",
      "description": "review changes [commit|branch|pr], defaults to uncommitted",
      "subtask": false,
    },
  },
}
